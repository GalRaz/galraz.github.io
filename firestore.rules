rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedUser() {
      return request.auth != null &&
             request.auth.token.email in ['galraz@gmail.com', 'kdaumk@gmail.com'];
    }

    function isOwnEntry() {
      return request.resource.data.addedBy == request.auth.uid;
    }

    // Shared two-person ledger: either partner can edit or soft-delete any
    // entry. The save handler stamps `editedBy` + `updatedAt` (and `deletedBy`
    // on soft-delete) so there's still an audit trail of who changed what.
    // Hard delete stays restricted to the original adder.

    match /expenses/{doc} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser() && isOwnEntry();
      allow update: if isAllowedUser();
      allow delete: if isAllowedUser() && resource.data.addedBy == request.auth.uid;
    }

    match /payments/{doc} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser() && isOwnEntry();
      allow update: if isAllowedUser();
      allow delete: if isAllowedUser() && resource.data.addedBy == request.auth.uid;
    }

    match /duels/{doc} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser();
      allow update: if isAllowedUser();
      allow delete: if isAllowedUser();
    }

    match /users/{userId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser() && userId == request.auth.uid;
    }

    match /settings/{doc} {
      allow read, write: if isAllowedUser();
    }

    match /recurring/{doc} {
      allow read, write: if isAllowedUser();
    }
  }
}
