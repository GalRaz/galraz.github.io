rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedUser() {
      return request.auth != null &&
             request.auth.token.email in ['galraz@gmail.com', 'kdaumk@gmail.com'];
    }

    function isOwnEntry() {
      return request.resource.data.addedBy == request.auth.uid;
    }

    // Soft-delete is allowed for either partner (shared ledger), but a
    // regular field edit is still restricted to the original adder so one
    // partner can't silently rewrite the other's entries.
    function isSoftDeleteOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['deletedAt', 'deletedBy']) &&
        request.resource.data.deletedBy == request.auth.uid;
    }

    match /expenses/{doc} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser() && isOwnEntry();
      allow update: if isAllowedUser() && (
        resource.data.addedBy == request.auth.uid || isSoftDeleteOnly()
      );
      allow delete: if isAllowedUser() && resource.data.addedBy == request.auth.uid;
    }

    match /payments/{doc} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser() && isOwnEntry();
      allow update: if isAllowedUser() && (
        resource.data.addedBy == request.auth.uid || isSoftDeleteOnly()
      );
      allow delete: if isAllowedUser() && resource.data.addedBy == request.auth.uid;
    }

    match /duels/{doc} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser();
      allow update: if isAllowedUser();
      allow delete: if isAllowedUser();
    }

    match /users/{userId} {
      allow read: if isAllowedUser();
      allow write: if isAllowedUser() && userId == request.auth.uid;
    }

    match /settings/{doc} {
      allow read, write: if isAllowedUser();
    }

    match /recurring/{doc} {
      allow read, write: if isAllowedUser();
    }
  }
}
